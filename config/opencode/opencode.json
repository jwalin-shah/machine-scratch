  "permission": {
    "edit": "allow",
    "read": "deny",
    "grep": "deny",
    "glob": "deny",
    "list": "deny",
    "bash": {
      "*": "ask",
      "rtk": "allow",
      "rtk *": "allow",
      "du -s": "allow",
      "du -sh": "allow",
      "du -s *": "allow",
      "du -sh *": "allow",
      "jq": "allow",
      "jq *": "allow",
      "yq": "allow",
      "yq *": "allow",
      "fastedit": "allow",
      "fastedit *": "allow",
      "llm-tldr": "allow",
      "llm-tldr *": "allow",
      "uv": "allow",
      "uv *": "allow",
      "gh-axi": "allow",
      "gh-axi *": "allow",
      "lavish-axi": "allow",
      "lavish-axi *": "allow",
      "chrome-devtools-axi": "allow",
      "chrome-devtools-axi *": "allow",
      "ctx7": "allow",
      "ctx7 *": "allow",
      "cognee-cli": "allow",
      "cognee-cli *": "allow",
      "cocoindex-code": "allow",
      "cocoindex-code *": "allow",
      "ccc": "allow",
      "ccc *": "allow",
      "treehouse": "allow",
      "treehouse *": "allow",
      "githits": "allow",
      "githits *": "allow",
      "ctx7 *": "allow",
      "inf": "allow",
      "inf *": "allow",
      "pioneer": "allow",
      "pioneer *": "allow",
      "bun": "allow",
      "bun *": "allow",
      "secret-cache exec *": "allow",
      "cat": "deny",
      "cat *": "deny",
      "ls": "deny",
      "ls *": "deny",
      "grep": "deny",
      "grep *": "deny",
      "find": "deny",
      "find *": "deny",
      "rg": "deny",
      "rg *": "deny",
      "eza": "deny",
      "eza *": "deny",
      "fd": "deny",
      "fd *": "deny",
      "bat": "deny",
      "bat *": "deny",
      "dust": "deny",
      "dust *": "deny",
      "du": "deny",
      "git": "deny",
      "git *": "deny",
      "gh": "deny",
      "gh *": "deny",
      "rm": "deny",
      "rm *": "deny",
      "sudo": "deny",
      "sudo *": "deny",
      "security": "deny",
      "security *": "deny",
      "export": "deny",
      "export *": "deny"
    },
    "webfetch": "ask",
    "websearch": "ask"
  },
  "shell": "zsh",
  "lsp": false,
  "instructions": [
    "~/.agent-rules/GLOBAL.md",
    "~/.agent-rules/TOOL_REGISTRY.md"
  ],
  "agent": {
    "build": {
      "model": "tokenrouter/deepseek/deepseek-v4-flash",
      "description": "Build agent following machine-scratch tool policy",
      "prompt": "Follow ~/.agent-rules/GLOBAL.md and TOOL_REGISTRY.md. Use rtk for read/grep/ls/find/git/gh/diff/test. Use du -s for disk usage (never dust). Use jq/yq for structured data. Use fastedit/llm-tldr when installed. Never call raw rg, eza, fd, bat, git, gh, or cat/ls/grep/find. Do not bypass permission denies."
    },
    "review": {
      "model": "tokenrouter/deepseek/deepseek-v4-flash",
      "description": "Review agent",
      "prompt": "Review for correctness, security, regressions, and missing tests. Follow ~/.agent-rules/GLOBAL.md."
    }
  }
}
